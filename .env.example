# --- LLM provider ---
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
EMBEDDING_MODEL=text-embedding-3-small

# --- Document processing ---
MAX_PDF_PAGES=500
MAX_UPLOAD_MB=25
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# --- RAG ---
RETRIEVAL_K=6
STUFF_THRESHOLD_TOKENS=12000

# --- App ---
LOG_LEVEL=INFO
DEBUG=false
